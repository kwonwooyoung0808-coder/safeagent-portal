APP_NAME=SafeAgent_Manager
APP_VERSION=0.2.0
UPDATE_CHANNEL=stable

POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://safeagent_app:change_me@postgres:5432/safeagent
POLICY_DIR=src/policies
PROMPT_DIR=src/prompts
WORKFLOW_NAME=governance_workflow

SYSTEM_INPUT_POLICY_ID=CONTENT_001
ENABLE_SELF_CONSISTENCY=false

GOVERNANCE_LLM_URL=http://host.docker.internal:11434
GOVERNANCE_LLM_MODEL=qwen2.5:7b
GOVERNANCE_LLM_TEMPERATURE=0.1

SOVEREIGN_AI_URL=http://host.docker.internal:11434
SOVEREIGN_AI_MODEL=qwen2.5:7b
SOVEREIGN_AI_TEMPERATURE=0.7
SOVEREIGN_ALLOWED_HOSTS=localhost,host.docker.internal,ollama

SAFE_RESPONSE_LLM_URL=http://host.docker.internal:11434
SAFE_RESPONSE_LLM_MODEL=llama3.2:3b
SAFE_RESPONSE_LLM_TEMPERATURE=0.3

SAFEAGENT_API_IMAGE=safeagent-api-local:v0.2.0
SAFEAGENT_FRONTEND_IMAGE=safeagent-portal-local:v0.2.0
